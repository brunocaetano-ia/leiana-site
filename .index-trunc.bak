<script>
(function(){
  "use strict";
  /* === CONFIGURAR: WhatsApp da Leiana (DDI+DDD+numero, só dígitos) === */
  var WHATS_LEIANA = "55619XXXXXXXX";   /* TROCAR pelo número real dela */
  var WHATS_BRUNO  = "5561998461172";

  document.querySelectorAll("[data-wa]").forEach(function(a){
    a.addEventListener("click",function(ev){
      ev.preventDefault();
      window.open("https://wa.me/"+WHATS_LEIANA+"?text="+encodeURIComponent(a.getAttribute("data-wa")),"_blank");
    });
  });

  var io = new IntersectionObserver(function(es){
    es.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add("in"); io.unobserve(e.target);} });
  },{threshold:.12});
  document.querySelectorAll(".reveal").forEach(function(el){ io.observe(el); });

  var burger=document.getElementById("burger"), links=document.getElementById("navlinks");
  if(burger){
    burger.addEventListener("click",function(){ links.classList.toggle("open"); });
    links.querySelectorAll("a").forEach(function(a){
      a.addEventListener("click",function(){ links.classList.remove("open"); });
    });
  }

  window.fecharModal = function(){ document.getElementById("modalRede").classList.remove("on"); };
  document.querySelectorAll(".soc[data-rede]").forEach(function(b){
    b.addEventListener("click",function(){
      var rede=b.getAttribute("data-rede");
      document.getElementById("modalTxt").innerHTML =
        "O seu <strong>"+rede+"</strong> ainda não existe. E se existisse? Imagine o seu cuidado chegando a milhares de pessoas que precisam exatamente do que você sabe fazer. A gente constrói esse canal para você, com a sua cara, sem você precisar virar marketeira.";
      document.getElementById("modalCta").href =
        "https://wa.me/"+WHATS_BRUNO+"?text="+encodeURIComponent("Olá, Bruno! Quero saber como criar meu "+rede+" profissional.");
      document.getElementById("modalRede").classList.add("on");
    });
  });
  document.getElementById("modalRede").addEventListener("click",function(e){
    if(e.target===this) fecharModal();
  });
})();
</script>
